# Database (default: SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./collected_company.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/collected_company

# Web server port (default: 8000)
PORT=8000

# Scryfall API
SCRYFALL_API_URL=https://api.scryfall.com

# Caching
CACHE_TTL_MINUTES=15

# Scraping
SCRAPER_TIMEOUT_SECONDS=15
SCRAPER_MAX_RETRIES=1

# Logging
LOG_LEVEL=INFO

# Sentry (optional)
# SENTRY_DSN=https://your-sentry-dsn-here

# CORS
# CORS_ORIGINS=["http://localhost:3000"]
